    "Apple Music access is required to recover original song and artist names." : {
      "comment" : "Alert title when MusicAuthorization is denied or restricted for the MusicKit name recovery toggle.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يلزم الوصول إلى Apple Music لاسترجاع أسماء الأغنية والفنان الأصلية."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Für die Wiederherstellung der originalen Titel- und Künstlernamen ist Zugriff auf Apple Music erforderlich."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se requiere acceso a Apple Music para recuperar los nombres originales de la canción y del artista."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "برای بازیابی نام اصلی آهنگ و هنرمند، دسترسی به Apple Music لازم است."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L’accès à Apple Music est requis pour récupérer les noms originaux du morceau et de l’artiste."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Akses ke Apple Music diperlukan untuk memulihkan nama lagu dan artis asli."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per recuperare i nomi originali di brano e artista è necessario l’accesso ad Apple Music."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "元の曲名とアーティスト名を復元するには、Apple Music へのアクセスが必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "원래 곡 및 아티스트 이름을 복원하려면 Apple Music 접근 권한이 필요합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toegang tot Apple Music is vereist om de oorspronkelijke nummer- en artiestnamen te herstellen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do odzyskania oryginalnych nazw utworu i wykonawcy wymagany jest dostęp do Apple Music."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "É necessário acesso ao Apple Music para recuperar os nomes originais da música e do artista."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для восстановления исходных названий песни и имени исполнителя требуется доступ к Apple Music."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Щоб відновити оригінальні назви пісні та виконавця, потрібен доступ до Apple Music."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要 Apple Music 访问权限才能恢复原始的歌曲和艺人名称。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "需要 Apple Music 取用權限才能還原原始的歌曲與藝人名稱。"
          }
        }
      }
    },
