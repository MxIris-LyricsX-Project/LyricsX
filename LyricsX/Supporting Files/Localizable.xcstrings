    "Start playback in the app you want to add, then try again." : {
      "comment" : "Body for the no-active-NowPlaying-source alert.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ابدأ التشغيل في التطبيق الذي تريد إضافته، ثم أعد المحاولة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Starte die Wiedergabe in der App, die du hinzufügen möchtest, und versuche es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inicia la reproducción en la app que quieres añadir y vuelve a intentarlo."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "در برنامه‌ای که می‌خواهید اضافه کنید پخش را آغاز کنید، سپس دوباره تلاش کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lancez la lecture dans l’app que vous souhaitez ajouter, puis réessayez."
