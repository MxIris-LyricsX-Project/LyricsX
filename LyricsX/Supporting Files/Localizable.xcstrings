    "Touch Bar lyrics is not supported in Mac App Store Version. Please download on GitHub." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ظهور الكلمات على شريط اللمس غير مدعومة في إصدار البرنامج المتوفر في متجر تطبيقات Mac. الرجاء التحميل على GitHub."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TouchBar-Songtexte werden nicht in der Mac App Store-Version unterstützt. Bitte laden Sie die entsprechende Version von GitHub herunter."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touch Bar lyrics is not supported in Mac App Store Version. Please download on GitHub."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Letras en la Touch Bar no está soportado en la versión de la Mac App Store. Por favor descárgate la versión de GitHub."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "نمایش متن ترانه در تاچ بار در نسخه دانلود شده از فروشگاه اپل پشتیبانی نمی شود. لطفا از نسخه موجود در گیتهاب استفاده کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les paroles sur la Touch Bar ne sont pas disponibles dans la version du Mac App Store. Veuillez télécharger la version sur GitHub."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Versi App Store Mac tidak mendukung lirik Batang Sentuh (Touch Bar). Silakan unduh di GitHub."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I testi nella Touch Bar non sono supportati nella versione Mac App Store. Scarica da GitHub."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タッチバーの歌詞は、Mac App Storeのバージョンではサポートされていません。 GitHubから最新バージョンをダウンロードしてください。"
          }
        },
        "ko" : {
