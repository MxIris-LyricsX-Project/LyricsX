    "Grant access in System Settings > Privacy & Security > Media & Apple Music, then try again." : {
      "comment" : "Alert body directing the user to System Settings to grant Apple Music access.",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "امنح الإذن من إعدادات النظام > الخصوصية والأمان > الوسائط و Apple Music، ثم أعد المحاولة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erteile den Zugriff unter „Systemeinstellungen“ > „Datenschutz & Sicherheit“ > „Medien & Apple Music“ und versuche es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Concede el acceso en Ajustes del Sistema > Privacidad y seguridad > Contenido multimedia y Apple Music y vuelve a intentarlo."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "در «تنظیمات سیستم > حریم خصوصی و امنیت > رسانه و Apple Music» دسترسی را اعطا کنید، سپس دوباره تلاش کنید."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorisez l’accès dans Réglages Système > Confidentialité et sécurité > Médias et Apple Music, puis réessayez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Berikan akses di Pengaturan Sistem > Privasi & Keamanan > Media & Apple Music, lalu coba lagi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Concedi l’accesso in Impostazioni di Sistema > Privacy e sicurezza > Contenuti multimediali e Apple Music, poi riprova."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「システム設定」>「プライバシーとセキュリティ」>「メディアと Apple Music」でアクセスを許可してから、もう一度お試しください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시스템 설정 > 개인 정보 보호 및 보안 > 미디어 및 Apple Music에서 접근 권한을 허용한 다음 다시 시도하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verleen toegang via Systeeminstellingen > Privacy en beveiliging > Media en Apple Music en probeer het opnieuw."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przyznaj dostęp w Ustawieniach systemowych > Prywatność i bezpieczeństwo > Multimedia i Apple Music, a następnie spróbuj ponownie."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conceda acesso em Ajustes do Sistema > Privacidade e Segurança > Mídia e Apple Music e tente novamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Предоставьте доступ в «Системные настройки» > «Конфиденциальность и безопасность» > «Медиа и Apple Music», затем повторите попытку."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Надайте доступ у «Системні параметри» > «Конфіденційність і безпека» > «Медіа та Apple Music», потім повторіть спробу."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请在「系统设置 > 隐私与安全性 > 媒体与 Apple Music」中授予权限，然后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "請在「系統設定 > 隱私權與安全性 > 媒體與 Apple Music」中授予權限，然後再試一次。"
          }
        }
      }
    },
