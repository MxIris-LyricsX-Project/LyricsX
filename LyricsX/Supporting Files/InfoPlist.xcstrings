    "NSAppleEventsUsageDescription" : {
      "comment" : "Privacy - AppleEvents Sending Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "البرنامج بحاجة إلى معرفة الأغنية التي تلعب حاليًا، لعرض كلمات الأغاني وفقاً لذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX muss wissen, welches Lied aktuell gespielt wird, um korrekte Liedtexte anzeigen zu können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "LyricsX needs to know what song you're currently playing, to show lyrics accordingly."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX necesita saber que canción se está reproduciéndo ahora, para mostrar letras acordemente."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "این برنامه برای نمایش متن ترانه نیاز دارد آهنگ در حال پخش شما رو بداند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX a besoin de savoir quelle chanson vous écoutez actuellement pour en afficher les paroles."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX harus mengetahui lagu apa yang sedang kamu putar untuk menampilkan lirik."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX deve sapere quale canzone stai attualmente riproducendo, per mostrarne il testo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX は現在再生中の音楽を取得し、それに応じて歌詞を表示する必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "가사를 표시하기 위해서 LyricsX는 당신이 현재 무슨 노래를 듣고 있는지 알아야 합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX moet weten welk nummer je momenteel aan het spelen bent om songteksten te laten zien."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX musi wiedzieć jaką piosenkę właśnie odtwarzasz, żeby wyświetlić odpowiedni tekst."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O LyricsX precisa saber qual música você está tocando no momento, para mostrar a letra de acordo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX нужно знать, какая песня сейчас играет, чтобы показывать соответствующий текст."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX повинен знати, яка пісня зараз грає, щоб показувати текст відповідно."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX 需要获取当前播放的音乐，并据此展示歌词"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX 需要了解你正在播放的音樂，並依此顯示歌詞。"
          }
        }
      }
    },
    "NSAppleMusicUsageDescription" : {
      "comment" : "Privacy - Media Library Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم LyricsX خدمة Apple Music للبحث عن العنوان والفنان الأصليين للمقطع حتى يتمكن من العثور على كلمات الأغاني للأسماء المترجمة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX verwendet Apple Music, um den ursprünglichen Titel und Künstler eines Songs zu ermitteln und so Songtexte für lokalisierte Namen zu finden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "LyricsX uses Apple Music to look up the original title and artist of a track so it can find lyrics for localized names."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX usa Apple Music para buscar el título y el artista originales de una pista y así encontrar la letra correspondiente a los nombres localizados."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX از Apple Music برای یافتن عنوان و هنرمند اصلی یک قطعه استفاده می‌کند تا بتواند متن ترانه را برای نام‌های بومی‌سازی‌شده پیدا کند."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX utilise Apple Music pour retrouver le titre et l’artiste d’origine d’un morceau afin de trouver les paroles correspondant aux noms localisés."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX menggunakan Apple Music untuk mencari judul dan artis asli sebuah lagu agar dapat menemukan lirik untuk nama yang dilokalkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX usa Apple Music per individuare il titolo e l’artista originali di un brano, così da trovare i testi per i nomi localizzati."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX は、ローカライズされた名称の歌詞を見つけられるように、Apple Music を使用して曲の元のタイトルとアーティストを調べます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX는 현지화된 이름의 가사를 찾을 수 있도록 Apple Music을 사용하여 트랙의 원래 제목과 아티스트를 조회합니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX gebruikt Apple Music om de oorspronkelijke titel en artiest van een nummer op te zoeken, zodat songteksten voor gelokaliseerde namen kunnen worden gevonden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX korzysta z Apple Music, aby wyszukać oryginalny tytuł i wykonawcę utworu i dzięki temu znaleźć teksty dla zlokalizowanych nazw."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O LyricsX usa o Apple Music para procurar o título e o artista originais de uma faixa, de modo a encontrar a letra correspondente a nomes localizados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX использует Apple Music для поиска исходного названия и исполнителя трека, чтобы находить тексты песен по локализованным названиям."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX використовує Apple Music для пошуку оригінальної назви та виконавця треку, щоб знаходити тексти пісень за локалізованими назвами."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX 使用 Apple Music 查询曲目的原始标题和艺人，以便为本地化名称查找歌词。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LyricsX 使用 Apple Music 查詢曲目的原始標題和藝人，以便為本地化名稱搜尋歌詞。"
          }
        }
      }
    },
