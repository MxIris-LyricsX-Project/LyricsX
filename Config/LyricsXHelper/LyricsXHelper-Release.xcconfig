// LyricsXHelper Release.

#include "LyricsXHelper.xcconfig"

CODE_SIGN_ENTITLEMENTS = LyricsXHelper/Supporting Files/LyricsXHelper-Release.entitlements
PRODUCT_BUNDLE_IDENTIFIER = $(LX_HELPER_BUNDLE_ID)

// Manual signing for distribution — see LyricsX-Release.xcconfig for the
// rationale. The Name matches the asc-created MAC_APP_DIRECT profile.
CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = Developer ID Application
PROVISIONING_PROFILE_SPECIFIER = LyricsXHelper Developer ID
